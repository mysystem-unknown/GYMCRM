generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Gym {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  address   String   @default("")
  phone     String   @default("")
  plan      String   @default("free")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     Member[]
  transactions Transaction[]
  expenses    Expense[]
  settings    Settings[]
  users       User[]
}

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  password            String
  name                String   @default("")
  role                String   @default("staff") // super_admin, admin, staff
  isActive            Boolean  @default(true)
  gymId               String?
  gym                 Gym?     @relation(fields: [gymId], references: [id], onDelete: SetNull)
  canRenewMemberships Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([gymId])
}

model ResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Settings {
  id                 String   @id @default(cuid())
  gymId              String   @unique
  gym                Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  openingCashBalance Float    @default(0)
  openingUpiBalance  Float    @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Member {
  id                  String   @id @default(cuid())
  gymId               String
  gym                 Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  memberId            String
  name                String
  phoneNumber         String   @default("")
  joinDate            DateTime
  expiryDate          DateTime
  membershipPlan      String   @default("1 Month")
  durationMonths      Int      @default(1)
  planPrice           Float    @default(0)
  currentCashPayment  Float    @default(0)
  currentUpiPayment   Float    @default(0)
  totalPayment        Float    @default(0)
  totalCash           Float    @default(0)
  totalUpi            Float    @default(0)
  pendingPayment      Float    @default(0)
  refundAmount        Float    @default(0)
  status              String   @default("Active")
  notes               String   @default("")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  transactions Transaction[]

  @@unique([gymId, memberId])
  @@index([gymId])
}

model Transaction {
  id           String   @id @default(cuid())
  gymId        String
  gym          Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  memberId     String
  member       Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  paymentMode  String   @default("Cash")
  amount       Float
  plan         String   @default("1 Month")
  duration     Int      @default(1)
  paymentDate  DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([gymId])
  @@index([memberId])
}

model Expense {
  id           String   @id @default(cuid())
  gymId        String
  gym          Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  category     String
  note         String   @default("")
  cashAmount   Float    @default(0)
  upiAmount    Float    @default(0)
  expenseDate  DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([gymId])
}
